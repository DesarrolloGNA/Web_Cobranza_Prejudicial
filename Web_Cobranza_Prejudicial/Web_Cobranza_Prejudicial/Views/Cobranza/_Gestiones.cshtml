@model Web_Cobranza_Prejudicial.Models.Entities.GESTIONES

<style>


    .scrolling-table-container_Gestiones{
        height: 345px;
        overflow-y: scroll;
        overflow-x: hidden;
    }
</style>





<div class="card">
    <div class="card-body">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#Gestiones_Prejudiciales">Gestiones Prejudicial</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#Gestiones_Judiciales">Gestiones Judiciales</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#Deuda">Deuda</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#Pagos">Pagos</a>
            </li>
        </ul>



        <div class="tab-content">


            <div id="Gestiones_Prejudiciales" class="tab-pane active">

                <div class="scrolling-table-container_Gestiones">
                    <table class="table table-striped table-bordered table-hover overflow-auto" style="width:100%;" name="Lista_Gestiones" id="Lista_Gestiones">

                        <thead>
                            <tr>
                                <th class="h6">#</th>
                                <th class="h6">FECHA REGISTRO</th>
                                <th class="h6">TELEFONO</th>
                                <th class="h6">RESPONSABLE</th>
                                <th class="h6">LUGAR</th>
                                <th class="h6">CONTACTO</th>
                                <th class="h6">EXCUSA</th>
                                <th class="h6">FECHA PROMESA</th>
                                <th class="h6">MONTO PROMESA</th>
                                <th class="h6">OBSERVACION</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var Registro in Model.GESTIONES_PREJUDICIALES.ToList())
                            {
                                <tr title="@Registro.OBSERVACION">
                                    <td class="h6">@Registro.ID_GESTIONES_PREJUDICIALES</td>
                                    <td class="h6">@Registro.FECHA_REGISTRO.ToString("dd-MM-yyyy HH:mm:ss")</td>
                                    <td class="h6">@Registro.TELEFONO</td>     
                                    <td class="h6">@Registro.NOMBRE_RESPONSABLE</td>
                                    <td class="h6">@Registro.LUGAR</td>
                                    <td class="h6">@Registro.RESPUESTA_CONTACTO</td>
                                    <td class="h6">@Registro.RESPUESTA_EXCUSA</td>

                                    <td class="h6">

                                        @if (@Registro.FECHA_PROMESA.ToString("yyyyMMdd")=="19000101")
                                        {

                                        }
                                        else
                                        {

                                            @Registro.FECHA_PROMESA.ToShortDateString()
                                        }

                                    
                                    
                                    </td>



                                    <td class="h6">
                                        @if (@Registro.MONTO_PROMESA == 0)
                                        {

                                        }
                                        else
                                        {

                                            @Registro.MONTO_PROMESA.ToString("N0")
                                        }
                                       
                                        
                                    
                                    </td>
                                    <td class="h6">
                                        @{
                                            var texto = Registro.OBSERVACION ?? "";
                                            var largoCorte = 45;

                                            var primeraParte = texto.Length > largoCorte
                                            ? texto.Substring(0, largoCorte)
                                            : texto;

                                            var segundaParte = texto.Length > largoCorte
                                            ? texto.Substring(largoCorte)
                                            : "";
                                        }


                                        <p>
                                            <span href="#" title="@Registro.OBSERVACION" data-bs-toggle="collapse" data-bs-target="#Gest_@Registro.ID_GESTIONES_PREJUDICIALES" style="cursor:pointer; text-decoration: underline;">
                                                @primeraParte
                                            </span><span id="Gest_@Registro.ID_GESTIONES_PREJUDICIALES" class="collapse">@segundaParte</span>
                                        </p>
                                
                                    </td>








                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>



            <div id="Gestiones_Judiciales" class="tab-pane fade">

                <div class="scrolling-table-container_Gestiones">

                    <table class="table table-striped table-bordered table-hover overflow-auto" style="width:100%;" name="Lista_Gestiones_Jud" id="Lista_Gestiones_Jud">

                        <thead>
                            <tr>
 
                                <th class="h6">#</th>
                                <th class="h6">FECHA_REGISTRO</th>
                                <th class="h6">NOMBRE_RESPONSABLE</th>
                                <th class="h6">RESPUESTA_CONTACTO</th>
                                <th class="h6">RESPUESTA_EXCUSA</th>
                                <th class="h6">OBSERVACION</th>
                                <th class="h6">TIPO_GESTION</th>
                                <th class="h6">FECHA_DILIGENCIA</th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var jud in Model.GESTIONES_JUDICIALES.ToList())
                            {



                                <tr title="@jud.OBSERVACION">
                                    <td class="h6">@jud.ID_GESTIONES_JUDICIALES</td>
                                    <td class="h6">@jud.FECHA_REGISTRO.ToString("dd-MM-yyyy HH:mm:ss")</td>
                                    <td class="h6">@jud.NOMBRE_RESPONSABLE</td>
                                    <td class="h6">@jud.RESPUESTA_CONTACTO</td>
                                    <td class="h6">@jud.RESPUESTA_EXCUSA</td>

                                    <td class="h6">
                                        @{
                                            var textoj = jud.OBSERVACION ?? "";
                                            var largoCortej = 50;

                                            var primeraParte = textoj.Length > largoCortej
                                            ? textoj.Substring(0, largoCortej)
                                            : textoj;

                                            var segundaParte = textoj.Length > largoCortej
                                            ? textoj.Substring(largoCortej)
                                            : "";
                                        }

                                        <p>
                                            <span href="#" title="@jud.OBSERVACION" data-bs-toggle="collapse" data-bs-target="#GestJ_@jud.ID_GESTIONES_JUDICIALES" style="cursor:pointer; text-decoration: underline;">
                                                @primeraParte
                                            </span><span id="GestJ_@jud.ID_GESTIONES_JUDICIALES" class="collapse">@segundaParte</span>
                                        </p>

                                    </td>
                                    <th class="h6">@jud.TIPO_GESTION</th>
                                    <td class="h6">

                                        @if (@jud.FECHA_DILIGENCIA.ToString("yyyyMMdd") == "19000101")
                                        {

                                        }
                                        else
                                        {

                                            @jud.FECHA_DILIGENCIA.ToShortDateString()
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>


                </div>


            </div>



            <div id="Deuda" class="container tab-pane fade">

                <div class="scrolling-table-container_Gestiones"></div>
            </div>

            <div id="Pagos" class="container tab-pane fade">
                <div class="scrolling-table-container_Gestiones"></div>
            </div>




        </div>
    </div>
</div>


