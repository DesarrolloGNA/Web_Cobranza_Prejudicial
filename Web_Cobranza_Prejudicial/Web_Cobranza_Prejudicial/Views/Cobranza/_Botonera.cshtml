@model Web_Cobranza_Prejudicial.Models.Entities.oSP_VALIDA_BOTONERA_X_ID_DEUDA
<style>
    .btn-fijo {
        width: 130px;
    }
</style>

@* <hr /> *@

<br />
<input type="hidden" id="BLOQUEO_LEY" name="BLOQUEO_LEY" value="@Model.BLOQUEO_LEY" />



<div class="card">
    <div class="card-body">
        @if(Model.ESTADO_DEUDA == 1)
        {
            <div class="btn-group">
      

                <button type="button" title="LLamar" class="btn btn-primary rounded btn-fijo" onclick="Funcion_CargarDiscador()" data-bs-toggle="modal" data-bs-target="#MODAL_REGISTRAR_GESTIONES"><img src="~/img/btnllamar.svg" width="20px;" height="20px;" /> LLamar</button>
                &nbsp;&nbsp;
                <button type="button" title="Presione aqui para registrar Gestion." onclick="Funcion_CargarRegistrarGestion()" data-bs-toggle="modal" data-bs-target="#MODAL_REGISTRAR_GESTIONES" class="btn btn-success rounded btn-fijo"><img src="~/img/btngrabargestion.svg" width="20px;" height="20px;" />Gestion Manual</button>
                &nbsp;&nbsp;
                <button type="button" title="Crear Telefono" data-bs-toggle="modal" onclick="Funcion_CargarRegistrarTelefono()" data-bs-target="#MODAL_REGISTRAR_TELEFONO" class="btn btn-info rounded btn-fijo"><img src="~/img/btnnuevotelefono.svg" width="20px;" height="20px;" /> Nuevo Fono</button>
                &nbsp;&nbsp;
                <button type="button" title="Crear Email" data-bs-toggle="modal" onclick="Funcion_CargarRegistrarEmail()" data-bs-target="#MODAL_REGISTRAR_EMAIL" class="btn btn-info rounded btn-fijo"><img src="~/img/btngrabaremail.svg" width="20px;" height="20px;" /> Nuevo Email</button>


        
       
            </div>
        }
        else
        {
            <button type="button" title="Presione aqui para registrar Gestion." onclick="Funcion_CargarRegistrarGestionRegularizados()" data-bs-toggle="modal" data-bs-target="#MODAL_REGISTRAR_GESTIONES_REGULARIZADOS" class="btn btn-warning rounded btn-fijo"><img src="~/img/btngrabargestion.svg" width="20px;" height="20px;" />Gestion Manual</button>

        }

    </div>
</div>
<br />
@* <hr /> *@

